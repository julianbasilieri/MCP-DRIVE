# ============================================================================
# CONFIGURACIÓN DE GOOGLE DRIVE MCP - Variables de Entorno
# ============================================================================
# Copia este archivo a .env y completa los valores según tu configuración
# NO commits de .env al repositorio (está en .gitignore)
# ============================================================================

# 🔒 CARPETA RAÍZ OBLIGATORIA (COMPARTIDA PARA TODO EL EQUIPO)
# NO MODIFICAR - Esta es la carpeta oficial del proyecto
# https://drive.google.com/drive/folders/13cEoJyVieAmc_S6aBMOoEt9us9gJT877
# Todos los archivos deben estar dentro de esta carpeta
# El valor está hardcodeado en config.py y no puede cambiar por usuario

# 🔐 AUTENTICACIÓN: Ruta al archivo de credenciales de Google Cloud
# Genera en: https://console.cloud.google.com/apis/credentials
# Descarga como JSON y guárdalo en la raíz del proyecto
GOOGLE_CLIENT_SECRET_PATH=./gcp-oauth.keys.json

# 🔐 TOKEN: Archivo donde se guardará el token de acceso OAuth2
# Se genera automáticamente en la primera ejecución
GOOGLE_DRIVE_MCP_TOKEN_FILE=./token_styles.json

# 📄 DOCUMENTO: ID del Google Doc a formatear con estilos
# Obtén el ID desde la URL del documento
GOOGLE_DOCS_ID=13OeKBKdRtsLYBhN-ro0cGLVTW_NkQgg1eSzaBZpaIuU

# ============================================================================
# JIRA MCP - Variables de Entorno
# ============================================================================

# Jira Cloud instance
JIRA_HOST=https://TU_DOMINIO.atlassian.net
JIRA_EMAIL=tu_email@example.com
JIRA_API_TOKEN=tu_token_jira_local

# ============================================================================
# NOTAS DE CONFIGURACIÓN
# ============================================================================
# 
# 1. CARPETA RAÍZ (DRIVE_ROOT_FOLDER_ID) - OBLIGATORIA Y FIJA
#    - Hardcodeada en config.py para todo el equipo
#    - NO puede modificarse por usuario
#    - Todas las operaciones SOLO funcionan dentro de esta carpeta
#    - Violaciones resultan en PermissionError
#
# 2. GOOGLE_CLIENT_SECRET_PATH
#    - Se recomienda mantener en la raíz del proyecto
#    - NO debe commitearse (está en .gitignore)
#    - Necesita scopes: drive, documents
#
# 3. GOOGLE_DRIVE_MCP_TOKEN_FILE
#    - Se genera automáticamente tras primera autenticación
#    - NO debe commitearse (está en .gitignore)
#    - Válido por ~3600 segundos, se refresca automáticamente
#
# 4. GOOGLE_DOCS_ID
#    - Documento específico a formatear
#    - Debe estar dentro de la CARPETA RAÍZ
#    - Opcional si solo usas otras funciones del MCP
#
