# Alternativa: configurar credenciales directamente como variables de entorno
# en lugar de usar el archivo gcp-oauth.keys.json
#
# Copia este archivo como .env y rellena los valores:
#   cp .env.example .env

GOOGLE_OAUTH_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-tu-client-secret
OAUTHLIB_INSECURE_TRANSPORT=0

# Jira MCP (mantener token solo en .env local)
JIRA_HOST=https://TU_DOMINIO.atlassian.net
JIRA_EMAIL=tu_email@example.com
JIRA_API_TOKEN=tu_token_local

# Drive MCP: ruta al client secret (si no se usa gcp-oauth.keys.json en raiz)
# GOOGLE_CLIENT_SECRET_PATH=./gcp-oauth.keys.json

# Opcional: directorio donde se guardan los tokens de sesion
# GOOGLE_MCP_CREDENTIALS_DIR=C:/Users/Tripulante/Desktop/PPS/.google_credentials
